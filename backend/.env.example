# Copy this file to .env and edit values as needed

# Use SQLite for the fastest zero-config local start:
DATABASE_URL=sqlite:///./ecosphere.db

# Or use PostgreSQL (recommended for production-like local dev, see docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://ecosphere:ecosphere@localhost:5432/ecosphere

SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
